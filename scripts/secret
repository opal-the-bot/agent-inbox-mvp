#!/bin/sh
set -eu

SECRETS_FILE="${SECRETS_FILE:-.secrets/keys.env}"
SECRETS_DIR=$(dirname "$SECRETS_FILE")

usage() {
  cat <<'EOF'
Usage:
  scripts/secret init
  scripts/secret set KEY [VALUE]
  scripts/secret unset KEY
  scripts/secret get KEY
  scripts/secret list
  scripts/secret path

Notes:
- Stores keys in .secrets/keys.env by default
- list output is masked
- set KEY without VALUE prompts securely
EOF
}

ensure_store() {
  mkdir -p "$SECRETS_DIR"
  [ -f "$SECRETS_FILE" ] || {
    {
      echo "# Local secrets (never commit)"
      echo "# Format: KEY=value"
    } > "$SECRETS_FILE"
  }
  chmod 700 "$SECRETS_DIR" || true
  chmod 600 "$SECRETS_FILE" || true
}

valid_key() {
  echo "$1" | grep -Eq '^[A-Z][A-Z0-9_]*$'
}

cmd="${1:-}"
case "$cmd" in
  init)
    ensure_store
    echo "Initialized $SECRETS_FILE"
    ;;

  set)
    [ "${2:-}" ] || { usage; exit 1; }
    key="$2"
    valid_key "$key" || { echo "Invalid key: use A-Z, 0-9, _ and start with A-Z"; exit 1; }
    ensure_store

    if [ "${3:-}" ]; then
      value="$3"
    else
      printf "Enter value for %s: " "$key" >&2
      stty -echo
      IFS= read -r value
      stty echo
      printf "\n" >&2
    fi

    tmp="$(mktemp)"
    awk -F= -v k="$key" 'BEGIN{OFS="="} $1!=k {print $0}' "$SECRETS_FILE" > "$tmp"
    printf '%s=%s\n' "$key" "$value" >> "$tmp"
    mv "$tmp" "$SECRETS_FILE"
    chmod 600 "$SECRETS_FILE" || true
    echo "Set $key"
    ;;

  unset)
    [ "${2:-}" ] || { usage; exit 1; }
    key="$2"
    ensure_store
    tmp="$(mktemp)"
    awk -F= -v k="$key" '$1!=k {print $0}' "$SECRETS_FILE" > "$tmp"
    mv "$tmp" "$SECRETS_FILE"
    chmod 600 "$SECRETS_FILE" || true
    echo "Unset $key"
    ;;

  get)
    [ "${2:-}" ] || { usage; exit 1; }
    key="$2"
    ensure_store
    value=$(awk -F= -v k="$key" '$1==k {sub(/^[^=]*=/,""); print; found=1; exit} END{if(!found) exit 1}' "$SECRETS_FILE") || {
      echo "Key not found: $key" >&2
      exit 1
    }
    printf '%s\n' "$value"
    ;;

  list)
    ensure_store
    awk -F= '
      /^[[:space:]]*#/ {next}
      /^[[:space:]]*$/ {next}
      {
        key=$1
        val=substr($0, index($0, "=")+1)
        n=length(val)
        if (n<=8) {
          masked="********"
        } else {
          masked=substr(val,1,4) "..." substr(val,n-3,4)
        }
        printf("%s=%s\n", key, masked)
      }
    ' "$SECRETS_FILE"
    ;;

  path)
    echo "$SECRETS_FILE"
    ;;

  ""|-h|--help|help)
    usage
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
